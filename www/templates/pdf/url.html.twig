{% extends 'base.html.twig' %}

{% block title %}URL vers PDF - DocuPDF{% endblock %}

{% block body %}
<div class="container fade-in mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="text-center mb-5">
                <h1 class="h2">Depuis une URL</h1>
                <p class="text-muted">Générez un PDF propre à partir de n'importe quelle page web publique.</p>
            </div>

            <div class="card">
                <div class="card-body p-5">
                    <form method="post" action="{{ path('app_pdf_url') }}">
                        <div class="mb-4">
                            <label for="url" class="form-label">URL de la page web</label>
                            <div class="input-group border-bottom">
                                <span class="input-group-text bg-transparent border-0 ps-0"><i class="bi bi-link-45deg"></i></span>
                                <input type="url" class="form-control border-0 ps-2" id="url" name="url" placeholder="https://www.example.com" required>
                            </div>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mt-5">
                            <a href="{{ path('app_pdf_dashboard') }}" class="text-muted text-decoration-none small"><i class="bi bi-arrow-left me-1"></i> Retour</a>
                            <button type="submit" class="btn btn-primary px-5">Générer le PDF</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
