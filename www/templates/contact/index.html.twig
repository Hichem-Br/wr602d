{% extends 'base.html.twig' %}

{% block title %}Mes Contacts - DocuPDF{% endblock %}

{% block body %}
<div class="container fade-in mt-5">
    <div class="row align-items-center mb-4">
        <div class="col-6">
            <h1 class="h2 mb-0">Carnet d'adresses</h1>
            <p class="text-muted small mb-0">Gérez les destinataires de vos documents.</p>
        </div>
        <div class="col-6 text-end">
            <a href="{{ path('app_contact_new') }}" class="btn btn-primary">
                <i class="bi bi-plus-lg me-2"></i>Nouveau Contact
            </a>
        </div>
    </div>

    <div class="row">
        <!-- Mes Contacts -->
        <div class="col-md-8">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-0">
                    {% if contacts is empty %}
                        <div class="text-center py-5">
                            <div class="mb-3 text-muted" style="font-size: 2.5rem;"><i class="bi bi-people"></i></div>
                            <h5 class="text-dark">Aucun contact trouvé</h5>
                            <p class="text-muted small mb-4">Ajoutez votre premier contact pour commencer.</p>
                            <a href="{{ path('app_contact_new') }}" class="btn btn-outline-primary btn-sm rounded-pill">Ajouter un contact manuel</a>
                        </div>
                    {% else %}
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="bg-light">
                                    <tr>
                                        <th class="border-0 ps-4 py-3 text-uppercase small text-muted font-monospace">Nom</th>
                                        <th class="border-0 py-3 text-uppercase small text-muted font-monospace">E-mail</th>
                                        <th class="border-0 pe-4 py-3 text-end text-uppercase small text-muted font-monospace">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for contact in contacts %}
                                        <tr>
                                            <td class="ps-4 fw-medium">{{ contact.firstname }} {{ contact.lastname }}</td>
                                            <td class="text-muted">{{ contact.email }}</td>
                                            <td class="pe-4 text-end">
                                                <a href="{{ path('app_history') }}" class="btn btn-sm btn-outline-primary rounded-pill me-2" title="Partager un PDF existant">
                                                    <i class="bi bi-send"></i> Envoyer un PDF
                                                </a>
                                                <a href="{{ path('app_contact_edit', {'id': contact.id}) }}" class="btn btn-link text-decoration-none text-muted p-0 me-3" title="Modifier">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <form method="post" action="{{ path('app_contact_delete', {'id': contact.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce contact ?');" style="display: inline-block;">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ contact.id) }}">
                                                    <button class="btn btn-link text-decoration-none text-danger p-0" title="Supprimer">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <!-- Suggestions réseau social -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                    <h5 class="card-title"><i class="bi bi-person-plus text-primary me-2"></i> Ajouter au réseau</h5>
                    <p class="text-muted small">Utilisateurs de DocuPDF que vous pourriez connaître.</p>
                </div>
                <div class="card-body pt-2">
                    {% if suggestions is empty %}
                        <p class="text-muted small">Aucune nouvelle suggestion pour le moment.</p>
                    {% else %}
                        <div class="list-group list-group-flush">
                            {% for user in suggestions %}
                                <div class="list-group-item px-0 border-bottom-0 d-flex justify-content-between align-items-center mb-2" id="suggestion-{{ user.id }}">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-light rounded-circle d-flex align-items-center justify-content-center text-primary fw-bold me-3" style="width: 40px; height: 40px;">
                                            {{ user.firstname ? user.firstname|first|upper : user.email|first|upper }}
                                        </div>
                                        <div>
                                            <h6 class="mb-0">{{ user.firstname }} {{ user.lastname }}</h6>
                                            <small class="text-muted">{{ user.email }}</small>
                                        </div>
                                    </div>
                                    <button class="btn btn-sm btn-outline-primary rounded-pill btn-add-ajax" data-user-id="{{ user.id }}">
                                        <i class="bi bi-plus-lg"></i>
                                    </button>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const buttons = document.querySelectorAll('.btn-add-ajax');
        buttons.forEach(btn => {
            btn.addEventListener('click', function() {
                const userId = this.getAttribute('data-user-id');
                const row = document.getElementById('suggestion-' + userId);
                
                // Show loading
                this.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>';
                this.classList.add('disabled');

                fetch('{{ path("app_contact_add_ajax") }}', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({ user_id: userId })
                })
                .then(response => response.json())
                .then(data => {
                    if(data.success) {
                        row.innerHTML = '<div class="alert alert-success w-100 py-2 mb-0 small"><i class="bi bi-check-circle me-1"></i> Ajouté avec succès</div>';
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        alert("Erreur lors de l'ajout du contact.");
                        this.innerHTML = '<i class="bi bi-plus-lg"></i>';
                        this.classList.remove('disabled');
                    }
                })
                .catch(error => {
                    alert("Erreur réseau.");
                    this.innerHTML = '<i class="bi bi-plus-lg"></i>';
                    this.classList.remove('disabled');
                });
            });
        });
    });
</script>
{% endblock %}
