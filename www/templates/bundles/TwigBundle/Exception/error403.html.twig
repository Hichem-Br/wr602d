{% extends 'base.html.twig' %}

{% block title %}Accès Refusé{% endblock %}

{% block body %}
<div class="row align-items-center justify-content-center" style="min-height: 60vh;">
    <div class="col-md-6 text-center">
        <i class="bi bi-shield-lock text-warning" style="font-size: 5rem;"></i>
        <h1 class="mt-4">Accès Restreint</h1>
        <p class="lead mt-3">
            Oups ! Vous n'avez pas l'abonnement requis pour accéder à cet outil !
        </p>
        <p class="text-muted">
            Votre plan actuel (<strong>{{ app.user ? app.user.plan.name : 'Déconnecté' }}</strong>) ne vous permet pas d'utiliser cette fonctionnalité. 
            Débloquez tout le potentiel de DocuPDF en passant au niveau supérieur.
        </p>
        <div class="mt-5">
            <a href="{{ path('app_subscription_change') }}" class="btn btn-primary px-4 py-2"><i class="bi bi-gem me-2"></i>Découvrir les offres</a>
            <a href="{{ path('app_pdf_dashboard') }}" class="btn btn-outline-secondary px-4 py-2 ms-3">Retour</a>
        </div>
    </div>
</div>
{% endblock %}
