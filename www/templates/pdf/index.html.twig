{% extends 'base.html.twig' %}

{% block title %}Tableau de bord - DocuPDF{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row align-items-center mb-5">
        <div class="col-12 col-md-6 mb-4 mb-md-0">
            <h1 class="h2">Créer un document</h1>
            <p class="text-muted">Sélectionnez une méthode pour générer votre PDF.</p>
        </div>
        <div class="col-12 col-md-6 text-md-end">
            <div class="d-inline-block text-start bg-light p-3 rounded" style="min-width: 280px; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted small fw-bold">Quota journalier</span>
                    <strong class="small">{{ quota_count }} / {{ quota_limit }} PDFs</strong>
                </div>
                <div class="progress" style="height: 12px; border-radius: 6px;">
                    {% set percent = quota_limit > 0 ? (quota_count / quota_limit) * 100 : 100 %}
                    <div class="progress-bar {% if percent >= 100 %}bg-danger{% else %}bg-primary{% endif %}" role="progressbar" style="width: {{ min(percent, 100) }}%"></div>
                </div>
                {% if quota_count >= quota_limit %}
                    <div class="text-danger small mt-2 fw-medium"><i class="bi bi-exclamation-triangle-fill"></i> Limite journalière atteinte.</div>
                {% endif %}
            </div>
        </div>
    </div>

    <div class="card-grid">
        <div class="card fade-in">
            <div class="card-body">
                <div class="card-icon"><i class="bi bi-link-45deg"></i></div>
                <h3>Depuis une URL</h3>
                <p>Convertissez n'importe quelle page web publique en un document PDF.</p>
                {% if quota_count >= quota_limit %}
                    <button disabled class="btn btn-secondary w-100 mt-3 d-flex justify-content-center align-items-center gap-2"><i class="bi bi-lock-fill"></i> Quota atteint</button>
                {% else %}
                    <a href="{{ path('app_pdf_url') }}" class="btn btn-primary w-100 mt-3">Utiliser une URL</a>
                {% endif %}
            </div>
        </div>

        <div class="card fade-in" style="animation-delay: 0.1s;">
            <div class="card-body">
                <div class="card-icon"><i class="bi bi-file-earmark-text"></i></div>
                <h3>Depuis un fichier</h3>
                <p>Convertissez des fichiers Word, Excel, PowerPoint ou HTML.</p>
                {% if quota_count >= quota_limit %}
                    <button disabled class="btn btn-secondary w-100 mt-3 d-flex justify-content-center align-items-center gap-2"><i class="bi bi-lock-fill"></i> Quota atteint</button>
                {% else %}
                    <a href="{{ path('app_pdf_file') }}" class="btn btn-primary w-100 mt-3">Importer un fichier</a>
                {% endif %}
            </div>
        </div>

        <div class="card fade-in" style="animation-delay: 0.2s;">
            <div class="card-body">
                <div class="card-icon"><i class="bi bi-pencil-square"></i></div>
                <h3>Éditeur personnalisé <span class="badge bg-warning ms-2" style="font-size: 0.6rem;">PRO</span></h3>
                <p>Rédigez ou collez du contenu directement dans notre éditeur de texte enrichi.</p>
                {% if not is_granted('ROLE_PREMIUM') %}
                    <a href="{{ path('app_subscription_change') }}" class="btn btn-outline-secondary w-100 mt-3 d-flex justify-content-center align-items-center gap-2"><i class="bi bi-lock-fill"></i> Passer Premium</a>
                {% elseif quota_count >= quota_limit %}
                    <button disabled class="btn btn-secondary w-100 mt-3 d-flex justify-content-center align-items-center gap-2"><i class="bi bi-lock-fill"></i> Quota atteint</button>
                {% else %}
                    <a href="{{ path('app_pdf_wysiwyg') }}" class="btn btn-primary w-100 mt-3">Ouvrir l'éditeur</a>
                {% endif %}
            </div>
        </div>
        
        <div class="card fade-in" style="animation-delay: 0.3s;">
            <div class="card-body">
                <div class="card-icon"><i class="bi bi-markdown"></i></div>
                <h3>Depuis du Markdown <span class="badge bg-warning ms-2" style="font-size: 0.6rem;">PRO</span></h3>
                <p>Convertissez facilement vos documents et notes en Markdown vers un PDF formaté.</p>
                {% if not is_granted('ROLE_PREMIUM') %}
                    <a href="{{ path('app_subscription_change') }}" class="btn btn-outline-secondary w-100 mt-3 d-flex justify-content-center align-items-center gap-2"><i class="bi bi-lock-fill"></i> Passer Premium</a>
                {% elseif quota_count >= quota_limit %}
                    <button disabled class="btn btn-secondary w-100 mt-3 d-flex justify-content-center align-items-center gap-2"><i class="bi bi-lock-fill"></i> Quota atteint</button>
                {% else %}
                    <a href="{{ path('app_pdf_markdown') }}" class="btn btn-primary w-100 mt-3">Éditeur Markdown</a>
                {% endif %}
            </div>
        </div>

        <div class="card fade-in" style="animation-delay: 0.4s;">
            <div class="card-body">
                <div class="card-icon"><i class="bi bi-code-slash"></i></div>
                <h3>Depuis du HTML brut <span class="badge bg-danger ms-2" style="font-size: 0.6rem;">ENTREPRISE</span></h3>
                <p>Générez des PDF avancés en collant directement votre code HTML et CSS.</p>
                {% if not is_granted('ROLE_ENTERPRISE') %}
                    <a href="{{ path('app_subscription_change') }}" class="btn btn-outline-secondary w-100 mt-3 d-flex justify-content-center align-items-center gap-2"><i class="bi bi-lock-fill"></i> Passer Entreprise</a>
                {% elseif quota_count >= quota_limit %}
                    <button disabled class="btn btn-secondary w-100 mt-3 d-flex justify-content-center align-items-center gap-2"><i class="bi bi-lock-fill"></i> Quota atteint</button>
                {% else %}
                    <a href="{{ path('app_pdf_html') }}" class="btn btn-primary w-100 mt-3">Coller du HTML</a>
                {% endif %}
            </div>
        </div>

        <div class="card fade-in" style="animation-delay: 0.5s;">
            <div class="card-body">
                <div class="card-icon"><i class="bi bi-camera"></i></div>
                <h3>Capture d'écran <span class="badge bg-danger ms-2" style="font-size: 0.6rem;">ENTREPRISE</span></h3>
                <p>Convertissez n'importe quelle page web publique en une image PNG.</p>
                {% if not is_granted('ROLE_ENTERPRISE') %}
                    <a href="{{ path('app_subscription_change') }}" class="btn btn-outline-secondary w-100 mt-3 d-flex justify-content-center align-items-center gap-2"><i class="bi bi-lock-fill"></i> Passer Entreprise</a>
                {% elseif quota_count >= quota_limit %}
                    <button disabled class="btn btn-secondary w-100 mt-3 d-flex justify-content-center align-items-center gap-2"><i class="bi bi-lock-fill"></i> Quota atteint</button>
                {% else %}
                    <a href="{{ path('app_pdf_screenshot') }}" class="btn btn-primary w-100 mt-3">Capturer l'URL</a>
                {% endif %}
            </div>
        </div>

        <div class="card fade-in" style="animation-delay: 0.6s;">
            <div class="card-body">
                <div class="card-icon"><i class="bi bi-intersect"></i></div>
                <h3>Fusionner des PDF <span class="badge bg-danger ms-2" style="font-size: 0.6rem;">ENTREPRISE</span></h3>
                <p>Combinez plusieurs fichiers PDF en un seul document. Traitement en arrière-plan.</p>
                {% if not is_granted('ROLE_ENTERPRISE') %}
                    <a href="{{ path('app_subscription_change') }}" class="btn btn-outline-secondary w-100 mt-3 d-flex justify-content-center align-items-center gap-2"><i class="bi bi-lock-fill"></i> Passer Entreprise</a>
                {% elseif quota_count >= quota_limit %}
                    <button disabled class="btn btn-secondary w-100 mt-3 d-flex justify-content-center align-items-center gap-2"><i class="bi bi-lock-fill"></i> Quota atteint</button>
                {% else %}
                    <a href="{{ path('app_pdf_merge') }}" class="btn btn-primary w-100 mt-3">Fusionner</a>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
