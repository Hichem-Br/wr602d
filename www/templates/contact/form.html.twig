{% extends 'base.html.twig' %}

{% block title %}{{ title }} - DocuPDF{% endblock %}

{% block body %}
<div class="container fade-in mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-transparent border-bottom py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-semibold">{{ title }}</h5>
                    <a href="{{ path('app_contact_index') }}" class="btn-close" aria-label="Close"></a>
                </div>
                <div class="card-body p-4">
                    {{ form_start(form) }}
                        <div class="mb-3">
                            {{ form_row(form.firstname, {
                                'attr': {'class': 'form-control bg-light border-0', 'placeholder': 'Prénom'},
                                'label_attr': {'class': 'form-label fw-medium'}
                            }) }}
                        </div>
                        <div class="mb-3">
                            {{ form_row(form.lastname, {
                                'attr': {'class': 'form-control bg-light border-0', 'placeholder': 'Nom'},
                                'label_attr': {'class': 'form-label fw-medium'}
                            }) }}
                        </div>
                        <div class="mb-4">
                            {{ form_row(form.email, {
                                'attr': {'class': 'form-control bg-light border-0', 'placeholder': 'Adresse E-mail'},
                                'label_attr': {'class': 'form-label fw-medium'}
                            }) }}
                        </div>
                        
                        <div class="d-grid">
                            <button class="btn btn-primary py-2">{{ button_label|default('Enregistrer le contact') }}</button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
