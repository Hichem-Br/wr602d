<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}DocuPDF{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⬜</text></svg>">
        
        <!-- Bootstrap 5 CSS -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <!-- Bootstrap Icons -->
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
        <!-- Custom Vibrant Design System -->
        <link rel="stylesheet" href="/css/custom.css">
        
        {% if app.user and app.user.favoriteColor %}
            <style>
                :root {
                    --primary-black: {{ app.user.favoriteColor }};
                    --bs-primary: {{ app.user.favoriteColor }};
                    --bs-btn-bg: {{ app.user.favoriteColor }};
                    --bs-btn-border-color: {{ app.user.favoriteColor }};
                }
                .btn-primary:hover {
                    background-color: transparent;
                    color: {{ app.user.favoriteColor }} !important;
                }
                .btn-outline-primary:hover {
                    background-color: {{ app.user.favoriteColor }} !important;
                    color: #ffffff !important;
                    border-color: {{ app.user.favoriteColor }} !important;
                }
                .text-dark {
                    color: {{ app.user.favoriteColor }} !important;
                }
            </style>
        {% endif %}

        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            <!-- Bootstrap 5 JS Bundle -->
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        {% endblock %}
    </head>
    <body>
        <nav class="navbar navbar-expand-lg navbar-light fixed-top">
            <div class="container">
                <a class="navbar-brand fw-bold" href="{{ path('homepage') }}">
                    <i class="bi bi-file-earmark-pdf-fill" style="color: var(--bs-primary); font-size: 1.2em;"></i> DocuPDF
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse" aria-controls="navbarCollapse" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarCollapse">
                    <ul class="navbar-nav me-auto mb-2 mb-md-0">
                        {% if is_granted('ROLE_USER') %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_pdf_dashboard') }}">Générer</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_history') }}">Archives</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_subscription_change') }}">Abonnement</a>
                            </li>
                        {% endif %}
                    </ul>
                    <ul class="navbar-nav ms-auto mb-2 mb-md-0 d-flex align-items-center">
                        {% if app.user %}
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-medium" href="{{ path('app_user_profile') }}">{{ app.user.userIdentifier }}</a>
                            </li>
                            <li class="nav-item ms-3">
                                <a class="btn btn-outline-primary btn-sm" href="{{ path('app_logout') }}">Déconnexion</a>
                            </li>
                        {% else %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_login') }}">Connexion</a>
                            </li>
                            <li class="nav-item ms-2">
                                <a class="btn btn-primary btn-sm" href="{{ path('app_register') }}">S'inscrire</a>
                            </li>
                        {% endif %}
                    </ul>
                </div>
            </div>
        </nav>
        <div style="height: 80px;"></div> <!-- Spacer for fixed navbar -->

        <div class="container">
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ type }} alert-dismissible fade show" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </div>
    </body>
</html>
