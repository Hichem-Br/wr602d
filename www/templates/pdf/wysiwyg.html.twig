{% extends 'base.html.twig' %}

{% block title %}Générer un PDF depuis l'éditeur{% endblock %}

{% block body %}
<div class="container mt-5">
    <h1 class="mb-4">Générer un PDF à partir d'un contenu personnalisé</h1>

    <div class="card p-4">
        <form method="post" action="{{ path('app_pdf_wysiwyg') }}">
            <div class="mb-3">
                <label for="content" class="form-label">Contenu</label>
                <textarea id="content" name="content"></textarea>
            </div>
            <button type="submit" class="btn btn-primary">Générer le PDF</button>
        </form>
    </div>
</div>

{# Summernote CSS #}
<link href="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-lite.min.css" rel="stylesheet">
{# JQuery (Required for Summernote) #}
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
{# Summernote JS #}
<script src="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-lite.min.js"></script>

<script>
    $(document).ready(function() {
        $('#content').summernote({
            placeholder: 'Rédigez votre contenu ici...',
            tabsize: 2,
            height: 400,
            toolbar: [
                ['style', ['style']],
                ['font', ['bold', 'underline', 'clear']],
                ['color', ['color']],
                ['para', ['ul', 'ol', 'paragraph']],
                ['table', ['table']],
                ['insert', ['link', 'picture', 'video']],
                ['view', ['fullscreen', 'codeview', 'help']]
            ]
        });
    });
</script>
{% endblock %}
