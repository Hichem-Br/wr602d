{% extends 'base.html.twig' %}

{% block title %}Fusionner des PDF - DocuPDF{% endblock %}

{% block body %}
<div class="row min-vh-100 flex-center">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="card p-4 p-md-5">
            <h2 class="h3 mb-4">Fusionner plusieurs PDF</h2>
            
            {{ include('_flash_messages.html.twig', ignore_missing = true) }}
            
            <form action="{{ path('app_pdf_merge') }}" method="POST" enctype="multipart/form-data">
                <div class="mb-4">
                    <label for="filesInput" class="form-label text-muted small text-uppercase">Fichiers PDF à fusionner</label>
                    <input type="file" class="form-control" id="filesInput" name="files[]" accept=".pdf,application/pdf" multiple required>
                    <div class="form-text">Maintenez la touche Ctrl/Cmd pour sélectionner plusieurs fichiers.</div>
                </div>
                
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-intersect me-2"></i>Fusionner les PDF
                </button>
            </form>
            
            <div class="text-center mt-4">
                <a href="{{ path('app_pdf_dashboard') }}" class="text-muted text-decoration-none small">
                    <i class="bi bi-arrow-left me-1"></i>Retour au tableau de bord
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
