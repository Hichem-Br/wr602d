{% extends 'base.html.twig' %}

{% block title %}Markdown vers PDF - DocuPDF{% endblock %}

{% block body %}
<div class="container fade-in mt-5">
    <div class="row align-items-center mb-5">
        <div class="col">
            <h1 class="h2">Markdown vers PDF</h1>
            <p class="text-muted">Écrivez ou collez votre code Markdown pour le convertir en un document PDF formaté.</p>
        </div>
        <div class="col-auto">
            <a href="{{ path('app_pdf_dashboard') }}" class="btn btn-outline-primary d-flex align-items-center gap-2">
                <i class="bi bi-arrow-left"></i> Retour
            </a>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card p-4">
                <form action="{{ path('app_pdf_markdown') }}" method="POST">
                    <div class="mb-4">
                        <label for="markdownContent" class="form-label text-muted text-uppercase mb-2" style="font-size: 0.8rem; letter-spacing: 0.1em;">Contenu Markdown</label>
                        <textarea class="form-control" name="content" id="markdownContent" rows="15" placeholder="# Titre Principal&#10;&#10;Ceci est un paragraphe.&#10;&#10;## Sous-titre&#10;- Liste d'éléments&#10;- **Texte en gras**" required style="font-family: monospace; background: var(--off-white); padding: 1rem; border-radius: var(--radius-md); resize: vertical;"></textarea>
                    </div>
                    
                    <button type="submit" class="btn btn-primary d-flex align-items-center gap-2">
                        <i class="bi bi-file-earmark-pdf"></i> Générer le PDF
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
