{% extends 'base.html.twig' %}

{% block title %}Réinitialiser votre mot de passe{% endblock %}

{% block body %}
    <div class="row align-items-center justify-content-center vh-100">
        <div class="col-md-6 col-lg-5">
            <div class="auth-card shadow-lg">
                <div class="auth-header">
                    <h2 class="auth-title">Réinitialiser le mot de passe</h2>
                </div>
                <div class="auth-body">
                    {% for flash_error in app.flashes('reset_password_error') %}
                        <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
                    {% endfor %}

                    {{ form_start(requestForm, {'attr': {'class': 'needs-validation'}}) }}
                        <div class="mb-3">
                            <label for="{{ requestForm.email.vars.id }}" class="form-label text-dark">Adresse e-mail</label>
                            {{ form_widget(requestForm.email, {'attr': {'class': 'form-control', 'placeholder': 'nom@entreprise.com'}}) }}
                            <div class="form-text text-muted">
                                Entrez votre adresse e-mail et nous vous enverrons un lien pour réinitialiser votre mot de passe.
                            </div>
                            <small class="text-danger">{{ form_errors(requestForm.email) }}</small>
                        </div>

                        <button class="btn btn-primary w-100 btn-lg shadow-sm" type="submit">Envoyer l'e-mail de réinitialisation</button>
                    {{ form_end(requestForm) }}

                    <div class="text-center mt-3">
                        <a href="{{ path('app_login') }}" class="text-secondary text-decoration-none">Retourner à la connexion</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
