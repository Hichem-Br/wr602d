{% extends 'base.html.twig' %}

{% block title %}Fichier vers PDF - DocuPDF{% endblock %}

{% block body %}
<div class="container fade-in mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="text-center mb-5">
                <h1 class="h2">Depuis un fichier</h1>
                <p class="text-muted">Convertissez vos documents locaux en PDF professionnels.</p>
            </div>

            <div class="card">
                <div class="card-body p-5">
                    <form method="post" action="{{ path('app_pdf_file') }}" enctype="multipart/form-data">
                        <div class="mb-4">
                            <label for="file" class="form-label">Importer un document</label>
                            <input type="file" class="form-control" id="file" name="file" required>
                            <div class="form-text text-muted mt-2">Prend en charge les fichiers HTML, Word, Excel et PowerPoint.</div>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mt-5">
                            <a href="{{ path('app_pdf_dashboard') }}" class="text-muted text-decoration-none small"><i class="bi bi-arrow-left me-1"></i> Retour</a>
                            <button type="submit" class="btn btn-primary px-5">Convertir maintenant</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
